      "Button.installForeground":     "classicText",
      "Button.installBorderColor":    "classicButtonDark",
      "Button.updateBackground":      "classicButtonFace",
      "Button.updateForeground":      "classicText",
      "Button.updateBorderColor":     "classicButtonDark",
      "Tab.selectedBackground":       "classicButtonFace",
      "Tab.selectedForeground":       "classicText",
      "Tab.hoverBackground":          "classicButtonLight",
      "SectionHeader.background":     "classicButtonShadow"
