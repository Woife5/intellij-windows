      "inactiveUnderlineColor":       "classicButtonShadow",
      "underlinedTabBackground":      "classicActiveTab",
      "hoverBackground":              "classicButtonLight"
    },

    "FileColor": {
      "Blue":                         "#d9e3f2",
      "Green":                        "#dcebd2",
      "Orange":                       "#f5dfc8",
      "Rose":                         "#efd6d3",
      "Violet":                       "#e6d9ef",
      "Yellow":                       "#f5edc6"
    },

    "Link": {
      "activeForeground":             "classicBlueLink",
