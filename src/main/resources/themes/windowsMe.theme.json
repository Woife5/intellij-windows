      "inactiveForeground":           "classicTextDisabled",
      "borderColor":                  "classicButtonShadow",
      "separatorColor":               "classicButtonShadow"
    },

    "ActionButton": {
      "hoverBackground":              "classicButtonLight",
      "hoverBorderColor":             "classicButtonDark",
      "pressedBackground":            "classicButtonLight",
      "pressedBorderColor":           "classicButtonDark"
    },

    "Button": {
      "background":                   "classicButtonFace",
      "foreground":                   "classicText",
      "startBackground":              "classicButtonFace",
      "endBackground":                "classicButtonFace",
      "startBorderColor":             "classicButtonLight",
      "endBorderColor":               "classicButtonDark",
      "focusedBorderColor":           "classicText",
      "default.background":           "classicButtonFace",
      "default.foreground":           "classicText",
      "default.startBackground":      "classicButtonFace",
      "default.endBackground":        "classicButtonFace",
      "default.startBorderColor":     "classicButtonLight",
      "default.endBorderColor":       "classicButtonDark",
      "default.focusedBorderColor":   "classicText"
