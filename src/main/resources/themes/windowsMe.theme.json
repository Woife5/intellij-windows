{
  "name": "Windows ME",
  "author": "Wolfgang",
  "dark": false,
  "editorScheme": "/colorSchemes/windowsClassic.xml",

  "colors": {
    "classicButtonFace":       "#ccc9c2",
    "classicButtonLight":      "#ece9d8",
    "classicActiveTab":        "#ddd9d1",
    "classicButtonShadow":     "#808080",
    "classicButtonDark":       "#404040",
    "classicWindowBg":         "#ffffff",
    "classicDesktop":          "#008080",
    "classicText":             "#000000",
    "classicTextDisabled":     "#808080",
    "classicTitlebar":         "#0a246a",
    "classicTitlebarInactive": "#808080",
    "classicTitleText":        "#ffffff",
    "classicSelection":        "#0a246a",
    "classicSelectionText":    "#ffffff",
    "classicScrollbar":        "#ccc9c2",
    "classicScrollThumb":      "#ccc9c2",
    "classicMenuBg":           "#ccc9c2",
    "classicInfoBg":           "#ffffe1",
    "classicError":            "#ff0000",
    "classicWarn":             "#808000",
    "classicInfo":             "#0a246a",
    "classicHint":             "#008080",
    "classicGreen":            "#008000",
    "classicMaroon":           "#800000",
    "classicPurple":           "#800080",
    "classicBlueLink":         "#0000ff",
    "classicGitAdd":           "#008000",
    "classicGitChange":        "#0a246a",
